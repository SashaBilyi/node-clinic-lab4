<%- include('../partials/header') %>

<div class="admin-container">
    <h2>Редагування даних фахівця</h2>
    
    <div class="admin-card" style="max-width: 500px; margin-top: 2rem;">
        <form action="/admin/doctors/update/<%= doctor.id %>" method="POST">
            <div class="form-group">
                <label>Повне ім'я:</label>
                <input type="text" name="name" value="<%= doctor.name %>" required>
            </div>
            <div class="form-group">
                <label>Спеціалізація:</label>
                <input type="text" name="specialty" value="<%= doctor.specialty %>" required>
            </div>
            
            <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
                <button type="submit" class="btn-success" style="flex: 2;">Зберегти зміни</button>
                <a href="/admin" class="btn-secondary" style="flex: 1; text-align: center;">Скасувати</a>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>